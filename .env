# 智能巡检系统配置文件

# 应用配置
APP_NAME=智能巡检系统
APP_VERSION=1.0.0

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=12305
DB_NAME=fire_patrol_system

# JWT配置
# 生产环境请使用随机生成的密钥，例如：openssl rand -hex 32
JWT_SECRET_KEY=5f8a1b3e7c9d2f4a8e6b0c1d3e5f7a9b2c4d6e8f0a2b4c6d8f0a1b3c5e7g9h0i
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# 密码配置
PASSWORD_HASH_ALGORITHM=bcrypt

# CORS跨域配置
# 允许的源列表，支持通配符*，多个源用逗号分隔
CORS_ORIGINS=["http://localhost:8080", "http://localhost:3000", "http://127.0.0.1:8080", "http://localhost:5173"]
# 是否允许携带凭证
CORS_ALLOW_CREDENTIALS=true
# 允许的HTTP方法
CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
# 允许的请求头
CORS_ALLOW_HEADERS=["*"]

# 限流配置
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_TIME_WINDOW=60

# LLM配置
DEEPSEEK_API_KEY=sk-75372ae7f2414446b35153ce5145bbd4
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# Socket服务器配置
SOCKET_PORT=9999
SOCKET_HOST=0.0.0.0
SOCKET_TIMEOUT=300000
MAX_CONNECTIONS=1000
BATCH_PROCESSING_ENABLED=false
BATCH_SIZE=10
COMPRESSION_ENABLED=false
ERROR_RETRY_LIMIT=3
ERROR_RETRY_DELAY=1000
HEARTBEAT_INTERVAL=30000
HEARTBEAT_TIMEOUT=90000
SMOKE_ALARM_THRESHOLD=50
FIRE_RISK_ALARM_THRESHOLD=2